// ===== TAB =====
function sw(t){S.tab=t;document.querySelectorAll('.nb').forEach((b,i)=>b.classList.toggle('on',['prompts','artists','clothing'][i]===t));document.querySelectorAll('.sec').forEach(s=>s.classList.toggle('on',s.id==='s-'+t));R()}

// ===== RENDER =====
function R(){if(S.tab==='prompts')rP();else if(S.tab==='artists')rA();else rC()}
function gT(a,f='tags'){const s=new Set();a.forEach(i=>(i[f]||[]).forEach(t=>s.add(t)));return[...s]}

// -- Prompt --
function rP(){
  const tags=gT(D.p);
  document.getElementById('pF').innerHTML=tags.map(t=>`<span class="ftg${S.pF===t?' on':''}" onclick="S.pF=S.pF==='${t}'?null:'${t}';R()">${t}</span>`).join('');
  let l=D.p,q=document.getElementById('pS').value.toLowerCase();
  if(q)l=l.filter(p=>p.title.toLowerCase().includes(q)||p.prompt.toLowerCase().includes(q)||p.tags.some(t=>t.includes(q)));
  if(S.pF)l=l.filter(p=>p.tags.includes(S.pF));
  const g=document.getElementById('pG');
  if(!l.length){g.innerHTML='<div class="empty"><p>暂无 prompt</p></div>';return}
  g.innerHTML=l.map((p,i)=>`<div class="cd" onclick="dP(${p.id})">
    ${p.img?`<img class="cd-img" src="${x(p.img)}" onerror="this.outerHTML='<div class=cd-ph>📷</div>'">`:'<div class="cd-ph">📷</div>'}
    <div class="cd-b"><div class="cd-h"><div class="cd-t">${x(p.title)}</div><div class="cd-n">#${String(i+1).padStart(3,'0')}</div></div>
    <div class="cd-d">${x(p.prompt)}</div>
    <div class="cd-tg">${p.tags.map(t=>`<span class="cd-tgi">${x(t)}</span>`).join('')}</div>
    <div class="cd-m"><span>${x(p.model||'')}</span><div class="cd-a">
      <button onclick="event.stopPropagation();cpx(${JSON.stringify(p.prompt)})" title="复制">${svgCp}</button>
      <button onclick="event.stopPropagation();oM('p',${p.id})" title="编辑">${svgEd}</button>
      <button onclick="event.stopPropagation();dl('p',${p.id})" title="删除">${svgDl}</button>
    </div></div></div></div>`).join('');
}

// -- Artist --
function rA(){
  const tags=gT(D.a);
  document.getElementById('aF').innerHTML=tags.map(t=>`<span class="ftg${S.aF===t?' on':''}" onclick="S.aF=S.aF==='${t}'?null:'${t}';R()">${x(t)}</span>`).join('');
  let l=D.a,q=document.getElementById('aS').value.toLowerCase();
  if(q)l=l.filter(a=>a.name.toLowerCase().includes(q)||a.string.toLowerCase().includes(q)||a.tags.some(t=>t.includes(q)));
  if(S.aF)l=l.filter(a=>a.tags.includes(S.aF));
  const g=document.getElementById('aG');
  if(!l.length){g.innerHTML='<div class="empty"><p>暂无画师串</p></div>';return}
  const mc=['mb0','mb1','mb2','mb3'];
  g.innerHTML=l.map(a=>{
    const imgs=a.images||[];
    const ih=imgs.length?imgs.slice(0,3).map(u=>`<img src="${x(u)}" onerror="this.outerHTML='<div class=ph>×</div>'">`).join(''):'<div class="ph">暂无</div><div class="ph"></div><div class="ph"></div>';
    return`<div class="cd" onclick="dA(${a.id})"><div class="cd-b">
      <div class="cd-h"><div class="cd-t">${x(a.name)}</div></div>
      <div class="ai-r">${ih}</div>
      <div class="cd-d">${x(a.string)}</div>
      <div style="margin-bottom:6px">${(a.models||[]).map((m,i)=>`<span class="mbdg ${mc[i%4]}">${x(m.name)}</span>`).join('')}</div>
      <div class="cd-tg">${a.tags.map(t=>`<span class="cd-tgi">${x(t)}</span>`).join('')}</div>
      <div class="cd-m"><span>${a.date||''}</span><div class="cd-a">
        <button onclick="event.stopPropagation();cpx(${JSON.stringify(a.string)})" title="复制">${svgCp}</button>
        <button onclick="event.stopPropagation();oM('a',${a.id})" title="编辑">${svgEd}</button>
        <button onclick="event.stopPropagation();dl('a',${a.id})" title="删除">${svgDl}</button>
      </div></div></div></div>`}).join('');
}

// -- Clothing --
function rC(){
  const cats=D.c.cats,items=D.c.items;
  // category filter
  const catsHtml=cats.map(c=>{
    const cnt=items.filter(i=>i.cat===c.id).length;
    return`<div class="cl-cat${S.cF===c.id?' on':''}" onclick="S.cF=S.cF==='${c.id}'?null:'${c.id}';rC()">${c.icon} ${x(c.name)} <span class="cnt">${cnt}</span></div>`;
  }).join('');
  document.getElementById('cCats').innerHTML=catsHtml;

  // filter
  let fl=items;
  if(S.cF)fl=fl.filter(i=>i.cat===S.cF);
  const q=document.getElementById('cS').value.toLowerCase();
  if(q)fl=fl.filter(i=>i.name.toLowerCase().includes(q)||i.en.toLowerCase().includes(q)||i.prompt.toLowerCase().includes(q));

  // selected items
  const selItems=items.filter(i=>S.sel.has(i.id));
  const bar=document.getElementById('cpBar');
  if(selItems.length){
    const combined=[...new Set(selItems.map(i=>i.prompt).filter(Boolean).join(', ').split(/,\s*/).filter(Boolean))].join(', ');
    bar.className='cp-bar show';
    bar.innerHTML=`<div class="cp-top">
      <div class="cp-info">已选择 <strong>${selItems.length}</strong> 件 · ${selItems.map(i=>i.name).join('、')}</div>
      <div class="cp-acts">
        <button class="cp-btn cp-all" onclick="selAll()">全选当前</button>
        <button class="cp-btn cp-clear" onclick="S.sel.clear();rC()">清除选择</button>
        <button class="cp-btn cp-copy" onclick="cpx('${combined.replace(/\\/g,'\\\\').replace(/'/g,"\\'")}')">📋 一键复制 Prompt</button>
      </div></div>
      <div class="cp-preview">${x(combined)}</div>`;
  } else {
    bar.className='cp-bar';
    bar.innerHTML='';
  }

  // grid
  const g=document.getElementById('cG');
  if(!fl.length){g.innerHTML='<div class="empty"><p>无匹配单品</p></div>';return}
  g.innerHTML=fl.map(i=>{
    const sel=S.sel.has(i.id);
    return`<div class="cl-it${sel?' sel':''}" onclick="tgSel(${i.id})">
      <div class="ck"></div>
      <div class="acts">
        <button onclick="event.stopPropagation();oM('cie',${i.id})" title="编辑">✎</button>
        <button onclick="event.stopPropagation();dlCI(${i.id})" title="删除">×</button>
      </div>
      ${i.img?`<img src="${x(i.img)}" onerror="this.outerHTML='<div class=iph>👘</div>'">`:'<div class="iph">👘</div>'}
      <div class="nm">${x(i.name)}</div>
      <div class="en">${x(i.en||'')}</div>
      <div class="pr">${x(i.prompt)}</div>
    </div>`}).join('');
}

function tgSel(id){if(S.sel.has(id))S.sel.delete(id);else S.sel.add(id);rC()}
function selAll(){
  let fl=D.c.items;
  if(S.cF)fl=fl.filter(i=>i.cat===S.cF);
  const q=document.getElementById('cS').value.toLowerCase();
  if(q)fl=fl.filter(i=>i.name.toLowerCase().includes(q)||i.en.toLowerCase().includes(q)||i.prompt.toLowerCase().includes(q));
  fl.forEach(i=>S.sel.add(i.id));rC();
}

