<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>雪色の画廊</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&family=Zen+Kaku+Gothic+New:wght@300;400;500&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#e8edec;--bg2:#f4f6f5;--bgc:#f0f4f3;--bgh:#e5ecea;
--mt:#8aa8a0;--mb:#94a7b0;--mg:#a3b5a6;--mm:#c2d1cc;--mf:#d0dbd7;--md:#6b8f86;--mk:#5a7a72;
--tp:#3d4f4a;--ts:#6b7f78;--tm:#8a9e96;
--bd:#c8d5d0;--sh:rgba(106,143,134,.08);--shh:rgba(106,143,134,.15);
--tbg:rgba(138,168,160,.15);--ttx:#5a7a72;--ov:rgba(61,79,74,.6)
}
body{font-family:'Zen Kaku Gothic New','Noto Serif JP',sans-serif;background:var(--bg);color:var(--tp);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(600px at 10% 20%,rgba(138,168,160,.12),transparent),radial-gradient(500px at 85% 70%,rgba(148,167,176,.1),transparent);pointer-events:none;z-index:0}
header{position:relative;z-index:1;text-align:center;padding:42px 20px 14px}
header h1{font-family:'Noto Serif JP',serif;font-weight:300;font-size:2.2rem;letter-spacing:.15em;background:linear-gradient(135deg,var(--md),var(--mb));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
header .sub{font-weight:300;font-size:.82rem;color:var(--tm);letter-spacing:.25em;margin-top:3px}
.hl{width:50px;height:1.5px;background:linear-gradient(90deg,transparent,var(--mt),transparent);margin:12px auto 0}
.nav{position:relative;z-index:2;display:flex;justify-content:center;gap:6px;padding:18px 20px 16px;flex-wrap:wrap}
.nb{padding:8px 22px;border-radius:22px;border:1px solid var(--bd);background:var(--bg2);font-family:inherit;font-size:.84rem;color:var(--ts);cursor:pointer;transition:all .3s}
.nb:hover{border-color:var(--mt);color:var(--mk)}
.nb.on{background:linear-gradient(135deg,var(--mt),var(--md));color:#fff;border-color:transparent;box-shadow:0 2px 12px rgba(106,143,134,.25)}
.sec{position:relative;z-index:1;max-width:1260px;margin:0 auto;padding:0 20px 50px;display:none}
.sec.on{display:block}

/* Controls */
.ctrl{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:18px}
.srch{flex:1;min-width:160px;max-width:320px;position:relative}
.srch input{width:100%;padding:8px 12px 8px 34px;border:1px solid var(--bd);border-radius:9px;background:var(--bg2);font-family:inherit;font-size:.84rem;color:var(--tp);outline:none;transition:border .3s,box-shadow .3s}
.srch input:focus{border-color:var(--mt);box-shadow:0 0 0 3px rgba(138,168,160,.12)}
.srch svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--tm);width:14px;height:14px}
.ft{display:flex;gap:5px;flex-wrap:wrap}
.ftg{padding:5px 12px;border-radius:16px;border:1px solid var(--bd);background:var(--bg2);font-size:.78rem;color:var(--ts);cursor:pointer;transition:all .3s;user-select:none}
.ftg:hover,.ftg.on{background:var(--mt);color:#fff;border-color:var(--mt)}
.ba{padding:8px 16px;border-radius:9px;border:none;background:linear-gradient(135deg,var(--mt),var(--md));color:#fff;font-family:inherit;font-size:.83rem;cursor:pointer;transition:all .3s;box-shadow:0 2px 8px rgba(106,143,134,.2);white-space:nowrap}
.ba:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(106,143,134,.3)}
.spacer{flex:1}

/* Grid */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px}

/* Card */
.cd{background:var(--bgc);border:1px solid var(--bd);border-radius:12px;transition:all .35s cubic-bezier(.4,0,.2,1);cursor:pointer;position:relative;overflow:hidden;display:flex;flex-direction:column}
.cd::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--mt),var(--mb),var(--mg));opacity:0;transition:opacity .3s}
.cd:hover{transform:translateY(-3px);box-shadow:0 8px 26px var(--shh);border-color:var(--mm);background:var(--bgh)}
.cd:hover::before{opacity:1}
.cd-img{width:100%;aspect-ratio:16/9;object-fit:cover;background:var(--mf);display:block}
.cd-ph{width:100%;aspect-ratio:16/9;background:linear-gradient(135deg,var(--mf),var(--mm));display:flex;align-items:center;justify-content:center;color:var(--tm);font-size:.84rem}
.cd-b{padding:16px;flex:1;display:flex;flex-direction:column}
.cd-h{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.cd-t{font-family:'Noto Serif JP',serif;font-weight:500;font-size:.98rem;color:var(--mk);line-height:1.5}
.cd-n{font-size:.7rem;color:var(--tm);background:var(--tbg);padding:2px 8px;border-radius:9px;white-space:nowrap}
.cd-d{font-size:.81rem;color:var(--ts);line-height:1.7;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;word-break:break-word}
.cd-tg{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px}
.cd-tgi{font-size:.71rem;padding:2px 8px;border-radius:10px;background:var(--tbg);color:var(--ttx)}
.cd-m{display:flex;justify-content:space-between;align-items:center;font-size:.73rem;color:var(--tm);border-top:1px solid var(--bd);padding-top:9px;margin-top:auto}
.cd-a{display:flex;gap:4px}
.cd-a button{background:none;border:none;color:var(--tm);cursor:pointer;padding:3px;border-radius:5px;transition:all .2s}
.cd-a button:hover{color:var(--md);background:var(--tbg)}
.ic-cp{width:14px;height:14px}

/* Artist mini images */
.ai-r{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;margin-bottom:10px}
.ai-r img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;background:var(--mf)}
.ai-r .ph{width:100%;aspect-ratio:1;background:var(--mf);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:var(--tm)}
.mbdg{display:inline-block;font-size:.68rem;padding:2px 7px;border-radius:7px;margin:0 3px 3px 0}
.mb0{background:rgba(138,168,160,.2);color:var(--mk)}.mb1{background:rgba(148,167,176,.2);color:#5a6f7a}.mb2{background:rgba(181,163,166,.2);color:#7a5a5f}.mb3{background:rgba(166,163,181,.2);color:#5f5a7a}

/* ===== CLOTHING ===== */
.cl-bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:16px}
.cl-cats{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.cl-cat{padding:8px 18px;border-radius:20px;border:1px solid var(--bd);background:var(--bg2);font-size:.84rem;color:var(--ts);cursor:pointer;transition:all .3s;user-select:none;display:flex;align-items:center;gap:5px}
.cl-cat:hover{border-color:var(--mt);color:var(--mk)}
.cl-cat.on{background:var(--mt);color:#fff;border-color:var(--mt)}
.cl-cat .cnt{font-size:.7rem;opacity:.7}

/* Copy bar */
.cp-bar{background:var(--bgc);border:1px solid var(--bd);border-radius:10px;padding:12px 16px;margin-bottom:16px;display:none}
.cp-bar.show{display:block}
.cp-top{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}
.cp-info{font-size:.84rem;color:var(--ts)}
.cp-info strong{color:var(--mk)}
.cp-acts{display:flex;gap:6px;flex-wrap:wrap}
.cp-btn{padding:7px 18px;border-radius:8px;border:none;font-family:inherit;font-size:.82rem;cursor:pointer;transition:all .3s}
.cp-copy{background:linear-gradient(135deg,var(--mt),var(--md));color:#fff;box-shadow:0 2px 8px rgba(106,143,134,.2)}
.cp-copy:hover{box-shadow:0 4px 16px rgba(106,143,134,.3)}
.cp-clear{background:var(--bg2);color:var(--ts);border:1px solid var(--bd)}
.cp-clear:hover{background:var(--bd)}
.cp-all{background:transparent;color:var(--md);border:1px solid var(--mt)}
.cp-all:hover{background:rgba(138,168,160,.1)}
.cp-preview{font-size:.8rem;color:var(--ts);line-height:1.6;word-break:break-all;max-height:60px;overflow-y:auto;background:var(--bg);border-radius:7px;padding:8px 10px;border:1px solid var(--bd)}

/* Clothing grid */
.cl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px}
.cl-it{background:var(--bgc);border:1px solid var(--bd);border-radius:10px;padding:10px;text-align:center;transition:all .3s;cursor:pointer;position:relative}
.cl-it:hover{transform:translateY(-2px);box-shadow:0 4px 14px var(--shh);border-color:var(--mm)}
.cl-it.sel{border-color:var(--mt);background:rgba(138,168,160,.1);box-shadow:0 0 0 2px rgba(138,168,160,.2)}
.cl-it img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px;background:var(--mf);margin-bottom:6px}
.cl-it .iph{width:100%;aspect-ratio:1;border-radius:6px;background:linear-gradient(135deg,var(--mf),var(--mm));display:flex;align-items:center;justify-content:center;color:var(--tm);font-size:1.5rem;margin-bottom:6px}
.cl-it .nm{font-size:.83rem;color:var(--tp);font-weight:500}
.cl-it .en{font-size:.72rem;color:var(--tm)}
.cl-it .pr{font-size:.7rem;color:var(--mt);margin-top:3px;font-style:italic;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
.cl-it .ck{position:absolute;top:6px;right:6px;width:22px;height:22px;border-radius:50%;border:2px solid var(--bd);background:var(--bg2);display:flex;align-items:center;justify-content:center;transition:all .25s}
.cl-it.sel .ck{background:var(--mt);border-color:var(--mt)}
.cl-it.sel .ck::after{content:'✓';color:#fff;font-size:.7rem}
.cl-it .acts{position:absolute;top:6px;left:6px;display:flex;gap:3px;opacity:0;transition:opacity .2s}
.cl-it:hover .acts{opacity:1}
.cl-it .acts button{width:22px;height:22px;border-radius:50%;border:none;background:rgba(0,0,0,.25);color:#fff;font-size:.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.cl-it .acts button:hover{background:rgba(0,0,0,.45)}

/* Modal */
.mo{display:none;position:fixed;inset:0;background:var(--ov);z-index:100;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.mo.show{display:flex}
.mbox{background:var(--bg2);border-radius:14px;padding:26px;width:92%;max-width:540px;max-height:88vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.15);animation:mi .3s ease}
@keyframes mi{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.mbox h2{font-family:'Noto Serif JP',serif;font-weight:400;font-size:1.08rem;color:var(--mk);margin-bottom:18px;letter-spacing:.05em}
.fg{margin-bottom:13px}
.fg label{display:block;font-size:.77rem;color:var(--ts);margin-bottom:4px}
.fg input,.fg textarea,.fg select{width:100%;padding:8px 11px;border:1px solid var(--bd);border-radius:8px;background:var(--bg);font-family:inherit;font-size:.84rem;color:var(--tp);outline:none;transition:border .3s}
.fg input:focus,.fg textarea:focus{border-color:var(--mt)}
.fg textarea{min-height:80px;resize:vertical;line-height:1.7}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.fg .hn{font-size:.7rem;color:var(--tm);margin-top:2px}
.mbt{display:flex;gap:8px;justify-content:flex-end;margin-top:18px}
.mbt button{padding:8px 20px;border-radius:8px;border:none;font-family:inherit;font-size:.84rem;cursor:pointer;transition:all .3s}
.bc{background:var(--bg);color:var(--ts);border:1px solid var(--bd)!important}
.bc:hover{background:var(--bd)}
.bs{background:linear-gradient(135deg,var(--mt),var(--md));color:#fff}
.bs:hover{box-shadow:0 4px 16px rgba(106,143,134,.3)}

/* Detail */
.dp{background:var(--bg);border-radius:8px;padding:12px;font-size:.84rem;line-height:1.8;color:var(--tp);margin:8px 0;word-break:break-all;white-space:pre-wrap;border:1px solid var(--bd)}
.cpb{padding:7px 15px;border-radius:7px;border:1px solid var(--mt);background:transparent;color:var(--md);font-family:inherit;font-size:.8rem;cursor:pointer;transition:all .3s}
.cpb:hover{background:var(--mt);color:#fff}
.di{font-size:.77rem;color:var(--tm);margin:4px 0}
.ad-imgs{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:6px;margin:10px 0}
.ad-imgs img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px;background:var(--mf);cursor:pointer;transition:transform .3s}
.ad-imgs img:hover{transform:scale(1.03)}

.lb{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:200;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(6px)}
.lb.show{display:flex}
.lb img{max-width:90%;max-height:90%;object-fit:contain;border-radius:8px}
.empty{grid-column:1/-1;text-align:center;padding:45px 20px;color:var(--tm)}
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--mk);color:#fff;padding:9px 26px;border-radius:10px;font-size:.84rem;opacity:0;transition:all .35s;z-index:300;pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,.2)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

@media(max-width:640px){
  header h1{font-size:1.7rem}
  .grid{grid-template-columns:1fr}
  .sec{padding:0 12px 40px}
  .mbox{padding:20px;width:96%}
  .fr{grid-template-columns:1fr}
  .cl-grid{grid-template-columns:repeat(auto-fill,minmax(120px,1fr))}
}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--mm);border-radius:3px}::-webkit-scrollbar-thumb:hover{background:var(--mt)}
</style>
</head>
<body>
