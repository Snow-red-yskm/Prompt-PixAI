  oMo('uMo');
}
function addMF(){const c=document.getElementById('mFs'),n=c.querySelectorAll('.mfn').length;c.insertAdjacentHTML('beforeend',`<div class="fr" style="margin-bottom:6px"><div class="fg" style="margin:0"><label>模型${n+1}</label><input class="mfn"></div><div class="fg" style="margin:0"><label>备注</label><input class="mfo"></div></div>`)}

function sF(){
  const t=S.et;
  if(t==='p'){
    const title=document.getElementById('f_t').value.trim(),prompt=document.getElementById('f_p').value.trim();
    if(!title||!prompt){alert('请填写标题和 Prompt');return}
    const o={title,prompt,negative:document.getElementById('f_n').value.trim(),tags:document.getElementById('f_tg').value.split(/[,，]/).map(s=>s.trim()).filter(Boolean),model:document.getElementById('f_m').value.trim(),img:document.getElementById('f_img').value.trim(),date:nd()};
    if(S.eid){const p=D.p.find(i=>i.id===S.eid);if(p)Object.assign(p,o)}else D.p.unshift({id:uid(),...o});
  } else if(t==='a'){
    const name=document.getElementById('f_nm').value.trim(),str=document.getElementById('f_st').value.trim();
    if(!name||!str){alert('请填写名称和画师串');return}
    const ns=document.querySelectorAll('.mfn'),os=document.querySelectorAll('.mfo'),models=[];
    for(let i=0;i<ns.length;i++){const n=ns[i].value.trim();if(n)models.push({name:n,notes:os[i]?.value.trim()||''})}
    const o={name,string:str,tags:document.getElementById('f_tg').value.split(/[,，]/).map(s=>s.trim()).filter(Boolean),models,images:document.getElementById('f_im').value.split('\n').map(s=>s.trim()).filter(Boolean),date:nd()};
    if(S.eid){const a=D.a.find(i=>i.id===S.eid);if(a)Object.assign(a,o)}else D.a.unshift({id:uid(),...o});
  } else if(t==='ci'||t==='cie'){
    const name=document.getElementById('f_cin').value.trim();
    if(!name){alert('请填写名称');return}
    const o={name,en:document.getElementById('f_cie').value.trim(),prompt:document.getElementById('f_cip').value.trim(),cat:document.getElementById('f_cic').value,img:document.getElementById('f_cii').value.trim()};
    if(t==='cie'&&S.eid){const it=D.c.items.find(i=>i.id===S.eid);if(it)Object.assign(it,o)}
    else D.c.items.push({id:uid(),...o});
  } else if(t==='cc'){
    const name=document.getElementById('f_cn').value.trim();
    if(!name){alert('请填写名称');return}
    const icon=document.getElementById('f_ci2').value.trim()||'🏷️';
    D.c.cats.push({id:name.toLowerCase().replace(/\s+/g,'_')+'_'+uid(),name,icon});
  }
  sv();cMo('uMo');R();
}

// ===== DETAIL =====
function dP(id){
  const p=D.p.find(i=>i.id===id);if(!p)return;
  document.getElementById('dMb').innerHTML=`<h2>${x(p.title)}</h2>
    ${p.img?`<img src="${x(p.img)}" style="width:100%;max-height:260px;object-fit:contain;border-radius:8px;background:var(--mf);margin-bottom:10px" onclick="slb('${x(p.img)}')">`:''}
    <div class="di">📅 ${p.date||''}　🔧 ${x(p.model||'')}</div>
    <div class="cd-tg" style="margin:8px 0">${p.tags.map(t=>`<span class="cd-tgi">${x(t)}</span>`).join('')}</div>
    <label style="font-size:.77rem;color:var(--tm)">Prompt</label><div class="dp">${x(p.prompt)}</div>
    ${p.negative?`<label style="font-size:.77rem;color:var(--tm)">Negative</label><div class="dp" style="border-left:3px solid var(--mb)">${x(p.negative)}</div>`:''}
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="cpb" onclick="cpx(${JSON.stringify(p.prompt)});this.textContent='已复制 ✓';setTimeout(()=>this.textContent='复制 Prompt',1200)">复制 Prompt</button>
      <button class="bc" onclick="cMo('dMo')">关闭</button></div>`;
  oMo('dMo');
}
function dA(id){
  const a=D.a.find(i=>i.id===id);if(!a)return;
  const mc=['mb0','mb1','mb2','mb3'];
  const imgs=(a.images||[]).map(u=>`<img src="${x(u)}" onclick="event.stopPropagation();slb('${x(u)}')" onerror="this.style.display='none'">`).join('');
  document.getElementById('dMb').innerHTML=`<h2>${x(a.name)}</h2>
    <div class="di">📅 ${a.date||''}</div>
    <div class="cd-tg" style="margin:8px 0">${a.tags.map(t=>`<span class="cd-tgi">${x(t)}</span>`).join('')}</div>
    <label style="font-size:.77rem;color:var(--tm)">画师串</label><div class="dp">${x(a.string)}</div>
    ${imgs?`<label style="font-size:.77rem;color:var(--tm)">画风展示</label><div class="ad-imgs">${imgs}</div>`:''}
    ${(a.models||[]).length?`<div style="margin:10px 0"><div style="font-size:.82rem;color:var(--ts);margin-bottom:6px;font-weight:500">模型表现对比</div>${a.models.map((m,i)=>`<div style="margin:5px 0;padding:8px;background:var(--bg);border-radius:7px;border:1px solid var(--bd)"><span class="mbdg ${mc[i%4]}">${x(m.name)}</span><span style="font-size:.82rem;color:var(--ts)">${x(m.notes)}</span></div>`).join('')}</div>`:''}
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="cpb" onclick="cpx(${JSON.stringify(a.string)});this.textContent='已复制 ✓';setTimeout(()=>this.textContent='复制画师串',1200)">复制画师串</button>
      <button class="bc" onclick="cMo('dMo')">关闭</button></div>`;
  oMo('dMo');
}

// ===== DELETE =====
function dl(k,id){if(!confirm('确定删除？'))return;D[k]=D[k].filter(i=>i.id!==id);sv();R()}
function dlCI(id){if(!confirm('确定删除？'))return;D.c.items=D.c.items.filter(i=>i.id!==id);S.sel.delete(id);sv();rC()}
function slb(u){document.getElementById('lbi').src=u;document.getElementById('lb').classList.add('show')}

// ===== INIT =====
ld();R();
document.getElementById('pS').addEventListener('input',R);
document.getElementById('aS').addEventListener('input',R);
document.getElementById('cS').addEventListener('input',rC);
